				{
					"name": "Вход и Получение Токена",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.token) {",
									"    pm.globals.set(\"token\", jsonData.token);",
									"    console.log(\"Token has been set to: \" + jsonData.token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"api_user\",\n    \"password\": \"password123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/login/",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"login",
								""
							]
						},
						"description": "Принимает username и password, возвращает Auth Token, который автоматически сохраняется в глобальную переменную `token`."
					},
					"response": []
				},
				{
					"name": "Выход (Удаление Токена)",
